A) Reconstruct repo
- Create a clean directory for the repo (e.g. /mnt/data/repo).
- Parse LLM_CONTEXT and materialize each file to disk at the exact path.
- Then copy LLM_CONTEXT_package-lock.json to repo/package-lock.json.
- Do not generate or modify the lockfile.
- Ensure exec bits on entrypoints (at minimum): chmod +x bin/wharfie install.sh build.js (and any file with a shebang).

Use this exact reconstruction script (only edit the source/target paths if needed):

python3 - <<'PY'
from pathlib import Path
import re, shutil, os

SRC = Path("/mnt/data/LLM_CONTEXT")
LOCK = Path("/mnt/data/LLM_CONTEXT_package-lock.json")
OUT = Path("/mnt/data/repo")

if OUT.exists():
    shutil.rmtree(OUT)
OUT.mkdir(parents=True, exist_ok=True)

text = SRC.read_text(encoding="utf-8")

marker = re.compile(r"^===== FILE: (.+?) =====\s*$", re.M)
matches = list(marker.finditer(text))
if not matches:
    raise SystemExit("ERROR: No '===== FILE:' markers found in LLM_CONTEXT")

for i, m in enumerate(matches):
    rel = m.group(1).strip()
    start = m.end()
    end = matches[i+1].start() if i+1 < len(matches) else len(text)
    body = text[start:end]

    # The dump inserts a newline after the marker line.
    if body.startswith("\n"):
        body = body[1:]

    # The dump also inserts separator blank lines between files.
    # Normalize file endings so Prettier --check doesn’t fail due to extra trailing newlines.
    body = body.rstrip("\n") + "\n"

    dest = OUT / rel
    dest.parent.mkdir(parents=True, exist_ok=True)
    dest.write_text(body, encoding="utf-8")

# Authoritative lockfile lives outside the dump
shutil.copyfile(LOCK, OUT / "package-lock.json")

# Fix executable bits for known entrypoints
for p in [
    OUT / "bin/wharfie",
    OUT / "install.sh",
    OUT / "build.js",
    OUT / "make_llm_context.sh",
]:
    if p.exists():
        p.chmod(p.stat().st_mode | 0o111)

print(f"OK: reconstructed {len(matches)} files into {OUT}")
PY

