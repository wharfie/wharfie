{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2021",
    "lib": ["ES2021", "dom"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["jest", "node"]
  },
  "include": [
    "lambdas/**/*.js",
    "cli/**/*.js",
    "test/**/*.js",
    "types/**/*.d.ts"
  ],
  "exclude": ["test/legacy/**", "test/__mocks__/**"]
}
